# Copy this file to .env.local and fill in your Firebase web app config.
# Do NOT commit .env.local; it's gitignored.
#
# All NEXT_PUBLIC_* variables are exposed to the browser and expected by
# Firebase Web SDK. They are NOT secrets; enforce security via Firebase rules
# and backend token verification.

# Firebase client config
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef1234567890
# Optional (only if you enabled Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Frontend app config
# Base URL of your backend (no trailing slash), e.g. http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=
# Optional logging level for client console logs
NEXT_PUBLIC_LOG_LEVEL=info
