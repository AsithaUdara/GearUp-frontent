# Copy this file to .env.local and fill in your Firebase web app config.
# Do NOT commit .env.local; it's gitignored.
#
# All NEXT_PUBLIC_* variables are exposed to the browser and expected by
# Firebase Web SDK. They are NOT secrets; enforce security via Firebase rules
# and backend token verification.

# Firebase client config
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef1234567890
# Optional (only if you enabled Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Frontend app config
# Preferred backend base via API Gateway (no trailing slash), e.g. http://localhost:8080
# If you use the Gateway, set this and send Authorization: Bearer <Firebase ID token>.
# The Gateway will validate the token and inject X-User-ID downstream.
# Example:
# NEXT_PUBLIC_API_BASE=http://localhost:8080

# Optional: direct service bases for local dev without Gateway
# Uncomment if you are calling services directly on 8083/8084
# NEXT_PUBLIC_API_BASE_VEHICLE=http://localhost:8083
# NEXT_PUBLIC_API_BASE_CUSTOMER=http://localhost:8084

# Legacy/alternate base URL used elsewhere in the app — keep if needed.
NEXT_PUBLIC_API_BASE_URL= http://localhost:8080

# Use Next.js dev proxy to bypass CORS when calling services directly
# Set to 1 to route API calls through /api/proxy/* instead of hitting services from the browser
NEXT_PUBLIC_USE_DEV_PROXY=0

# Dev-only local uploads: set to 1 to store images under public/local_uploads
# Leave unset or 0 in production; Firebase Storage will be used instead.
# NEXT_PUBLIC_LOCAL_UPLOAD=1

# Optional logging level for client console logs
NEXT_PUBLIC_LOG_LEVEL=info
